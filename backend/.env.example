PORT=3000
CLIENT_ORIGIN=http://localhost:5173

GEMINI_API_KEY=your_google_ai_studio_key
GEMINI_MODEL=gemini-2.5-flash

ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Veo video generation (uses GEMINI_API_KEY above — no extra key needed)
VEO_MODEL=veo-2.0-generate-001
VEO_ASPECT_RATIO=16:9
VEO_DURATION_SECONDS=5
VEO_WAIT_TIMEOUT_MS=600000

# Optional: only used by backend/vision_test.py prototype.
GOOGLE_VISION_API_KEY=your_google_cloud_vision_key
